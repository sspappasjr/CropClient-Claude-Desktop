<!--
  web.config for iisnode
  Tells IIS to route all requests through Node.js via iisnode
  Target: APIServer2.0.js in the api-server folder on the production server
  URL: https://api.cropclient.com/*

  Deploy this file to the same folder as APIServer2.0.js on the server.
  Requires iisnode module installed on IIS.
-->
<configuration>
  <system.webServer>

    <!-- iisnode configuration -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      loggingEnabled="true"
      logDirectory="iisnode"
      watchedFiles="*.js;web.config"
      promiseRejectionHandlingMode="unhandledrejections"
    />

    <!-- URL Rewrite: send ALL requests to APIServer2.0.js -->
    <handlers>
      <add name="iisnode" path="APIServer2.0.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- SSL: Redirect HTTP to HTTPS -->
        <rule name="HTTPSRedirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- Don't rewrite requests for node inspector (debugging) -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^APIServer2.0.js\/debug[\/]?" />
        </rule>

        <!-- Rewrite everything else to APIServer2.0.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="APIServer2.0.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Let Express handle errors, not IIS -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
