<!--
  web.config for iisnode
  Tells IIS to route all requests through Node.js via iisnode
  Target: APIServer1.3.js in the api-server folder on the production server
  URL: https://api.cropclient.com/*

  Deploy this file to the same folder as APIServer1.3.js on the server.
  Requires iisnode module installed on IIS.
-->
<configuration>
  <system.webServer>

    <!-- iisnode configuration -->
    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      loggingEnabled="true"
      logDirectory="iisnode"
      watchedFiles="*.js;web.config"
      promiseRejectionHandlingMode="unhandledrejections"
    />

    <!-- URL Rewrite: send ALL requests to APIServer1.3.js -->
    <handlers>
      <add name="iisnode" path="APIServer1.3.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Don't rewrite requests for node inspector (debugging) -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^APIServer1.3.js\/debug[\/]?" />
        </rule>

        <!-- Rewrite everything else to APIServer1.3.js -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="APIServer1.3.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Let Express handle errors, not IIS -->
    <httpErrors existingResponse="PassThrough" />

  </system.webServer>
</configuration>
